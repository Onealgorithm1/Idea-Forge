{
  "name": "ideaforge-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "start": "npm start --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix idea-forge",
    "build:frontend": "npm run build --prefix idea-forge"
  },
  "workspaces": [
    "backend",
    "idea-forge"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
